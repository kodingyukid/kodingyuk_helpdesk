<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_helpdesk_ticket_tree" model="ir.ui.view">
        <field name="name">kodingyuk.helpdesk.ticket.tree</field>
        <field name="model">kodingyuk.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'new'" decoration-warning="state == 'in_progress'" decoration-success="state == 'solved'">
                <field name="name"/>
                <field name="date"/>
                <field name="staff_id"/>
                <field name="system_id"/>
                <field name="issue_type_id"/>
                <field name="state" widget="badge" decoration-info="state == 'new'" decoration-warning="state == 'in_progress'" decoration-success="state == 'solved'"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">kodingyuk.helpdesk.ticket.form</field>
        <field name="model">kodingyuk.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_upload_attachment" string="Upload Attachment" type="object" class="oe_highlight" invisible="state == 'solved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,solved" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="staff_id"/>
                            <field name="system_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="issue_type_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detail Masalah" name="details">
                            <group>
                                <field name="chronology"/>
                                <field name="data_to_fix"/>
                            </group>
                        </page>
                        <page string="Lampiran Bukti (Firebase)" name="attachments">
                            <field name="attachment_ids" mode="tree">
                                <tree create="0" delete="1" edit="0">
                                    <field name="preview_html" widget="html" string="Preview" style="width: 110px;"/>
                                    <field name="name"/>
                                    <field name="mimetype"/>
                                    <field name="url" widget="url" readonly="1" text="Buka Link"/>
                                    <button name="action_open_link" string="Lihat Full" type="object" icon="fa-external-link"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View with Grouping -->
    <record id="view_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">kodingyuk.helpdesk.ticket.search</field>
        <field name="model">kodingyuk.helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="staff_id"/>
                <field name="system_id"/>
                <filter string="Baru" name="new_tickets" domain="[('state', '=', 'new')]"/>
                <filter string="Dalam Proses" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Selesai" name="solved" domain="[('state', '=', 'solved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Staff" name="group_by_staff" context="{'group_by': 'staff_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Tanggal" name="group_by_date" context="{'group_by': 'date'}"/>
                    <filter string="Sistem" name="group_by_system" context="{'group_by': 'system_id'}"/>
                    <filter string="Jenis Masalah" name="group_by_issue" context="{'group_by': 'issue_type_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_helpdesk_ticket" model="ir.actions.act_window">
        <field name="name">Helpdesk Ticket</field>
        <field name="res_model">kodingyuk.helpdesk.ticket</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_helpdesk_ticket_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Buat ticket helpdesk baru!
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_helpdesk_root" name="Helpdesk KodingYuk" sequence="10" groups="group_helpdesk_staff"/>
    <menuitem id="menu_helpdesk_ticket" name="Tickets" parent="menu_helpdesk_root" action="action_helpdesk_ticket" sequence="10"/>

    <menuitem id="menu_helpdesk_alat" name="Alat" parent="menu_helpdesk_root" sequence="50" groups="group_helpdesk_staff"/>
    <menuitem id="menu_helpdesk_password_generator" name="Generator Password" parent="menu_helpdesk_alat" action="action_helpdesk_password_generator_wizard" sequence="10"/>

    <!-- Configuration Master Menus -->
    <menuitem id="menu_helpdesk_config" name="Configuration" parent="menu_helpdesk_root" sequence="100" groups="group_helpdesk_manager"/>
    
    <!-- Issue Type -->
    <record id="view_helpdesk_issue_type_tree" model="ir.ui.view">
        <field name="name">helpdesk.issue.type.tree</field>
        <field name="model">helpdesk.issue.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="action_helpdesk_issue_type" model="ir.actions.act_window">
        <field name="name">Jenis Masalah</field>
        <field name="res_model">helpdesk.issue.type</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_helpdesk_issue_type" name="Jenis Masalah" parent="menu_helpdesk_config" action="action_helpdesk_issue_type" sequence="10"/>

    <!-- System Type -->
    <record id="view_helpdesk_system_type_tree" model="ir.ui.view">
        <field name="name">helpdesk.system.type.tree</field>
        <field name="model">helpdesk.system.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="action_helpdesk_system_type" model="ir.actions.act_window">
        <field name="name">Master Sistem</field>
        <field name="res_model">helpdesk.system.type</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_helpdesk_system_type" name="Master Sistem" parent="menu_helpdesk_config" action="action_helpdesk_system_type" sequence="20"/>
</odoo>
