<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_password_generator_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.password.generator.wizard.form</field>
        <field name="model">helpdesk.password.generator.wizard</field>
        <field name="arch" type="xml">
            <form string="Generator Password">
                <sheet>
                    <group>
                        <field name="employee_id" options="{'no_create': True}"/>
                        <field name="user_id" readonly="1"/>
                    </group>
                    <field name="info_html" nolabel="1"/>
                    <group string="Password baru" invisible="not generated_password">
                        <field name="generated_password" widget="CopyClipboardChar"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_password" string="Generate Password" type="object" class="btn-primary"/>
                    <button name="action_apply_to_user" string="Terapkan ke User" type="object" class="btn-secondary"
                            invisible="not generated_password"/>
                    <button string="Tutup" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_password_generator_wizard" model="ir.actions.act_window">
        <field name="name">Generator Password</field>
        <field name="res_model">helpdesk.password.generator.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
